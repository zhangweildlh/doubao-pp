{
  "name": "doubao-pp",
  "description": "为豆包网页版提供记忆、技能与自动化能力的浏览器扩展（Deepseek-pp 移植）",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:edge": "wxt build --browser edge",
    "build:firefox": "wxt build --browser firefox --mv3",
    "build:all": "npm run build:chrome && npm run build:edge && npm run build:firefox",
    "zip": "wxt zip",
    "zip:chrome": "wxt zip --browser chrome",
    "zip:edge": "wxt zip --browser edge",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "test": "vitest run",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": ">=0.0.260",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wxt": "^0.20.0"
  }
}
